# Copy this file to ".env" (same folder) and fill in your values.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
NOTION_TOKEN=ntn_...                # Notion internal integration token
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxx # the database (data source) ID

# --- Trigger mode ---
# TRIGGER_MODE=interval     # "interval" = every N min, "watch" = on every file save
# WATCH_DEBOUNCE_MS=2000    # watch mode: merge-window so one save = one entry (0 = every raw event)

# --- Optional (defaults shown) ---
# CHECK_INTERVAL_MINUTES=30 # only used when TRIGGER_MODE=interval
# CLAUDE_MODEL=claude-sonnet-4-6
# GIT_REPO_PATH=                    # defaults to the project root
# EXCLUDE_PATHS=node_modules,dist   # comma-separated paths kept out of the diff
# MAX_DIFF_CHARS=60000

# --- Notion column names (must match your database exactly) ---
# NOTION_PROP_NAME=Name             # the Title column
# NOTION_PROP_CHINESE=中文          # a Text column
# NOTION_PROP_DESCRIPTION=description # a Text column
